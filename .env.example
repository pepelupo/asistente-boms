PORT=3000
DATA_DIR=./data
DATABASE_URL=

# Zoho OAuth app
ZOHO_CLIENT_ID=pegar_client_id
ZOHO_CLIENT_SECRET=pegar_client_secret
ZOHO_REDIRECT_URI=http://localhost:3000/api/auth/zoho/callback
ZOHO_ACCOUNTS_BASE=https://accounts.zoho.com
ZOHO_CRM_BASE=https://www.zohoapis.com/crm/v8
ZOHO_SCOPES=ZohoCRM.modules.ALL,ZohoCRM.settings.READ

# OpenAI API
OPENAI_API_KEY=pegar_openai_api_key
OPENAI_MODEL=gpt-5.2

# Custom tools para Zia Agents
ZIA_TOOL_SECRET=generar_un_token_largo_y_privado
PUBLIC_BASE_URL=https://asistente-boms.bessel.com.ar

